FEATURE_FLAGS=trading,kyc
ENCRYPTION_KEY=local-dev-secret
PII_ENCRYPTION_KEY=local-pii-secret

# Supabase — replace with real values from your Supabase project dashboard
# Project ref: jfhojgtnmcfqretrrxam
# Without real values the API will start but all database queries will fail.
SUPABASE_URL=https://jfhojgtnmcfqretrrxam.supabase.co
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# OpenAI — replace with your actual key; placeholder lets the server boot
# without crashing (AI routes will return 401 until a real key is set).
OPENAI_API_KEY=sk-placeholder-key-replace-me

# Sentry — replace with your real DSN from sentry.io (optional — set to any
# non-empty string to pass the startup guard if you are not using Sentry).
SENTRY_DSN=https://placeholder@placeholder.ingest.sentry.io/0

# Stripe — replace with your real secret key from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_placeholder_replace_me
