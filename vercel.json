{
  "installCommand": "npm install --prefix ui",
  "buildCommand": "npm run build --prefix ui",
  "outputDirectory": "ui/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://kontra-api.onrender.com/api/$1"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "",
    "VITE_API_URL": "https://kontra-api.onrender.com",
    "VITE_SUPABASE_URL": "https://jfhojgtnmcfqretrrxam.supabase.co"
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!api|assets|.*\\.).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}
