# When VITE_FORCE_RELATIVE_API=true all /api/* calls go to the Vite dev server
# which proxies them to the local kontra API on port 3000 (see vite.config.js).
VITE_FORCE_RELATIVE_API=true
VITE_API_PROXY_PORT=3000

# Fallback absolute URL used only when VITE_FORCE_RELATIVE_API=false
VITE_API_BASE_URL=https://kontra-api.onrender.com

VITE_SENTRY_DSN=<your-dsn-here>
# Comma separated list of enabled frontend modules
VITE_FEATURE_FLAGS=trading

# Supabase credentials — required for login
# Project ref: jfhojgtnmcfqretrrxam
VITE_SUPABASE_URL=https://jfhojgtnmcfqretrrxam.supabase.co
VITE_SUPABASE_ANON_KEY=
