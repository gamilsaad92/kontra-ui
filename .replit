modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Kontra UI Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Kontra API Backend"

[[workflows.workflow]]
name = "Kontra UI Dashboard"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd kontra-ui-clone/ui && node node_modules/vite/bin/vite.js"
waitForPort = 5173

[[workflows.workflow]]
name = "Kontra API Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd kontra-ui-clone/api && PORT=3001 NODE_ENV=development SUPABASE_URL=${SUPABASE_URL:-https://placeholder.supabase.co} SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY:-placeholder-key} OPENAI_API_KEY=${OPENAI_API_KEY} node index.js"
waitForPort = 3001

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "104f3d700a890f9cd8cb2dae1b8ebb4f3a6d1df6952e7fcf19b30460f57f0412a747ce2e6dd6d7247d1a7aef4c916e51"
